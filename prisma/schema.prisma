generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  STAFF
  MEMBER
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum GivingType {
  TITHE
  OFFERING
  PLEDGE
  THANKSGIVING
  OTHER
}

enum TransferType {
  PERMANENT
  TEMPORARY
}

enum ReceiptStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum RequestStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

model Church {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  email      String?
  phone      String?
  address    String?
  websiteUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users           User[]
  districts       District[]
  ministries      Ministry[]
  events          Event[]
  news            NewsArticle[]
  sermons         Sermon[]
  mlagaItems      MlagaSchedule[]
  vacancies       Vacancy[]
  apiClients      ApiClient[]
  joinRequests    MembershipRequest[]
  contactMessages ContactMessage[]
}

model User {
  id           String     @id @default(cuid())
  churchId     String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(MEMBER)
  status       UserStatus @default(ACTIVE)
  firstName    String
  lastName     String
  phone        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  church        Church            @relation(fields: [churchId], references: [id], onDelete: Cascade)
  member        MemberProfile?
  permissions   UserPermission[]
  sessions      Session[]
  offerings     OfferingReceipt[]
  newsAuthored  NewsArticle[]     @relation("NewsAuthor")
  eventsMade    Event[]           @relation("EventCreator")
  sermonsMade   Sermon[]          @relation("SermonCreator")
  vacanciesMade Vacancy[]         @relation("VacancyCreator")

  @@index([churchId, role])
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  lastSeenAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model Permission {
  id          String @id @default(cuid())
  key         String @unique
  description String

  users UserPermission[]
}

model UserPermission {
  userId       String
  permissionId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

model District {
  id          String   @id @default(cuid())
  churchId    String
  name        String
  area        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  church     Church          @relation(fields: [churchId], references: [id], onDelete: Cascade)
  members    MemberProfile[]
  mlagaItems MlagaSchedule[]

  @@unique([churchId, name])
}

model MemberProfile {
  id                String        @id @default(cuid())
  userId            String        @unique
  churchId          String
  districtId        String?
  memberNumber      String?
  gender            String?
  maritalStatus     String?
  previousChurch    String?
  currentLocation   String?
  baptizedAt        String?
  currentWork       String?
  transferType      TransferType?
  transferLetterUrl String?
  joinedAt          DateTime?
  bio               String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  district           District?            @relation(fields: [districtId], references: [id])
  verificationChecks MemberVerification[]

  @@unique([churchId, memberNumber])
  @@index([churchId, districtId])
}

model Ministry {
  id          String        @id @default(cuid())
  churchId    String
  name        String
  slug        String
  description String
  imageUrl    String?
  status      ContentStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@unique([churchId, slug])
}

model Event {
  id          String        @id @default(cuid())
  churchId    String
  title       String
  slug        String
  description String
  startsAt    DateTime
  endsAt      DateTime?
  venue       String
  imageUrl    String?
  status      ContentStatus @default(PUBLISHED)
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  church    Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("EventCreator", fields: [createdById], references: [id])

  @@unique([churchId, slug])
  @@index([churchId, startsAt])
}

model NewsArticle {
  id          String        @id @default(cuid())
  churchId    String
  title       String
  slug        String
  excerpt     String
  body        String
  imageUrl    String?
  publishedAt DateTime?
  status      ContentStatus @default(PUBLISHED)
  authorId    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  author User?  @relation("NewsAuthor", fields: [authorId], references: [id])

  @@unique([churchId, slug])
  @@index([churchId, publishedAt])
}

model Sermon {
  id          String        @id @default(cuid())
  churchId    String
  title       String
  slug        String
  passage     String
  preacher    String
  series      String?
  videoUrl    String?
  imageUrl    String?
  preachedAt  DateTime
  status      ContentStatus @default(PUBLISHED)
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  church    Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("SermonCreator", fields: [createdById], references: [id])

  @@unique([churchId, slug])
  @@index([churchId, preachedAt])
}

model MlagaSchedule {
  id         String   @id @default(cuid())
  churchId   String
  districtId String?
  host       String
  preacher   String
  venue      String
  startsAt   DateTime
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  church   Church    @relation(fields: [churchId], references: [id], onDelete: Cascade)
  district District? @relation(fields: [districtId], references: [id])

  @@index([churchId, startsAt])
}

model Vacancy {
  id           String        @id @default(cuid())
  churchId     String
  title        String
  slug         String
  type         String
  department   String
  summary      String
  requirements String[]
  closingAt    DateTime?
  status       ContentStatus @default(PUBLISHED)
  createdById  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  church    Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("VacancyCreator", fields: [createdById], references: [id])

  @@unique([churchId, slug])
}

model OfferingReceipt {
  id         String        @id @default(cuid())
  churchId   String
  userId     String?
  fullName   String
  phone      String
  district   String?
  type       GivingType
  amount     Decimal       @db.Decimal(12, 2)
  receiptUrl String
  status     ReceiptStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([churchId, userId])
  @@index([churchId, createdAt])
}

model MembershipRequest {
  id                   String        @id @default(cuid())
  churchId             String
  firstName            String
  lastName             String
  gender               String
  maritalStatus        String
  primaryPhone         String
  otherPhone           String?
  email                String?
  previousChurch       String
  currentLocation      String
  baptizedAt           String?
  currentWork          String?
  preferredService     String
  transferType         TransferType
  transferLetterStatus String
  transferLetterUrl    String?
  familyMembers        String?
  notes                String?
  status               RequestStatus @default(PENDING)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId, status])
}

model ContactMessage {
  id        String        @id @default(cuid())
  churchId  String
  name      String
  phone     String?
  email     String
  subject   String
  message   String
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId, status])
}

model ApiClient {
  id        String   @id @default(cuid())
  churchId  String
  name      String
  keyHash   String
  scopes    String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId, active])
}

model MemberVerification {
  id               String   @id @default(cuid())
  memberProfileId  String
  requestingChurch String?
  requestRef       String?
  result           String
  checkedAt        DateTime @default(now())

  memberProfile MemberProfile @relation(fields: [memberProfileId], references: [id], onDelete: Cascade)
}
